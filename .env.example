# Exemplo de variáveis de ambiente - Copie este arquivo para .env e preencha com seus dados

# 1. Configurações de Banco de Dados
DATABASE_URL=sua_url_de_conexao_aqui

# 2. Configurações de Autenticação (JWT)
JWT_SECRET=seu_segredo_jwt_aqui

# 3. Configurações do Cloudinary (Upload de imagens)
CLOUDINARY_CLOUD_NAME=seu_cloud_name_aqui
CLOUDINARY_API_KEY=sua_api_key_aqui
CLOUDINARY_API_SECRET=seu_api_secret_aqui

# 4. Outras Chaves de API (ex: Claude se aplicável no futuro)
CLAUDE_API_KEY=sua_chave_aqui_nao_preencher
