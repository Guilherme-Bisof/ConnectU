// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  RECRUITER
}

model Company {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  logoUrl     String?
  website     String?

  members User[]
  jobs    Job[]

  createdAt DateTime @default(now())
}

model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String
  role       Role    @default(STUDENT)
  avatarUrl  String?
  bannerUrl  String?
  degreeType String?
  startDate  String?
  endDate    String?
  bio        String?
  resumeUrl  String?
  isPioneer  Boolean @default(false)
  location   String?

  // Carreira e Status 
  currentCompany String? // Onde o aluno trabalha atualmente
  isOpenToWork   Boolean @default(false) // Se está procurando emprego

  // Específico para Alunos
  course      String?
  institution String?
  skills      String[] // ["Next.js", "Node", "PostgreSQL"]
  githubUrl   String?

  // Links Personalizados (Portfólio, YouTube, etc)
  links    Link[]
  projects Project[]

  // Aplicação de vagas
  applications Application[]

  // Configurações do usuário
  mutedRooms String[] @default([])

  // Relacionamentos
  posts         Post[]
  rooms         Room[]         @relation("UserRooms")
  messages      Message[]
  likes         Like[]
  comments      Comment[]
  notifications      Notification[]
  sentNotifications  Notification[] @relation("NotificationSender")

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
}

model Link {
  id    String @id @default(uuid())
  label String // Título do link (ex: "YouTube", "Portfólio")
  url   String // A URL real

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Job {
  id              String   @id @default(uuid())
  title           String
  type            String
  description     String?
  requiredSkills  String[]
  desirableSkills String[]
  isInternship    Boolean  @default(false)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  applications Application[]
}

model Post {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  likes    Like[]
  comments Comment[]
}

// Projetos
model Project {
  id          String  @id @default(uuid())
  title       String
  description String
  link        String?
  imageUrl    String?

  // Relacionamento
  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

enum ChatContext {
  SOCIAL
  PROFESSIONAL
}

model Room {
  id        String      @id @default(uuid())
  context   ChatContext @default(SOCIAL)
  jobId     String? // Atrelado a uma vaga se for profissional
  messages  Message[]
  createdAt DateTime    @default(now())

  users User[] @relation("UserRooms")
}

model Message {
  id        String   @id @default(uuid())
  content   String?  // Alterado para opcional caso o usuário queira mandar apenas a imagem
  imageUrl  String?
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id])

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])
}

model Application {
  id        String   @id @default(uuid())
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  // Relação com o Aluno (user)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relação com Vaga (job)
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  // Utilizador para não poder se candidatar duas vezes
  @@unique([userId, jobId])
}

model Like {
  id     String @id @default(uuid())
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  postId    String
  userId    String

  // Relações
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  senderId    String?
  type        String
  title       String
  content     String
  read        Boolean  @default(false)
  postId      String?
  metadata    Json?
  resourceUrl String?
  createdAt   DateTime @default(now())

  // Relações
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender User? @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([senderId])
  @@index([read])
  @@index([createdAt])
}
